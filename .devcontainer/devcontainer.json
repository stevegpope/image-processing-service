{
	"name": "Image Processor Service",
	"image": "mcr.microsoft.com/devcontainers/java:17",
	"features": {
		"ghcr.io/devcontainers/features/terraform:1": {
			"version": "latest",
			"tflint": "latest"
		},
		"ghcr.io/devcontainers/features/aws-cli:1": "latest",
		"ghcr.io/devcontainers/features/python:1": "latest",
		"ghcr.io/devcontainers/features/powershell:1": "latest"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"java.configuration.updateBuildConfiguration": "automatic",
				"terraform.languageServer.external": true
			},
			"extensions": [
				"vscjava.vscode-java-pack",
				"hashicorp.terraform",
				"amazonwebservices.aws-toolkit-vscode",
				"ms-python.python",
				"redhat.vscode-xml",
				"ms-vscode.powershell"
			]
		},
		"jetbrains": {
			"plugins": [
				"com.intellij.java",
				"org.jetbrains.plugins.terraform",
				"com.amazon.aws.toolkit"
			]
		}
	},
	"containerEnv": {
		"ENVIRONMENT": "local",
		"MOTO_URL": "http://localhost:4566",
		"AWS_REGION": "us-east-1",
		"AWS_ACCESS_KEY_ID": "test",
		"AWS_SECRET_ACCESS_KEY": "test"
	},
	"postCreateCommand": "pip3 install pre-commit moto[server] && pre-commit install && tflint --init",
	"postStartCommand": "moto_server -p 4566 &",
	"remoteUser": "vscode"
}
